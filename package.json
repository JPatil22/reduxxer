{
  "name": "tokenreduxxer",
  "version": "0.2.0",
  "description": "A local daemon that incrementally indexes a JS/TS/Python repo and serves targeted code context over MCP, instead of AI coding tools re-reading whole files/repo every time.",
  "type": "module",
  "bin": {
    "tokenreduxxer": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "python",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p .",
    "prepublishOnly": "npm run build",
    "index": "node dist/src/cli.js index",
    "watch": "node dist/src/cli.js watch",
    "mcp": "node dist/src/cli.js mcp",
    "benchmark": "node dist/demo/benchmark.js",
    "test": "node --test dist/test/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JPatil22/reduxxer.git"
  },
  "homepage": "https://github.com/JPatil22/reduxxer",
  "bugs": {
    "url": "https://github.com/JPatil22/reduxxer/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "cursor",
    "ai-coding",
    "code-search",
    "token-savings"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^3.6.0",
    "ignore": "^7.0.6",
    "porter-stemmer": "^0.9.1",
    "typescript": "^5.5.4",
    "usearch": "^2.26.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.9"
  }
}
